# SiliconCloud API Key (DeepSeek-V3)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Database file path (relative to backend/)
DATABASE_PATH=data/leximind.db

# ----- Backend runtime config (optional, defaults shown) -----

# Host the Flask server binds to. Default 127.0.0.1 (loopback only) is safest for
# local single-user use. Set to 0.0.0.0 ONLY when you need remote access, e.g.
# when running behind nginx in Docker (docker-compose already does this).
# NEVER set 0.0.0.0 together with FLASK_ENV=development — that exposes the
# Werkzeug debugger on all interfaces.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# production = no debug console; development = enables Flask debugger
# (use development only on a trusted local machine)
FLASK_ENV=production

# How many history rows to keep before the oldest are pruned
MAX_HISTORY_RECORDS=1000

# Rate limiting / input limits
RATE_LIMIT_PER_IP=10
MAX_INPUT_LENGTH=2000

LOG_LEVEL=INFO
