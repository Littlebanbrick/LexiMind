# ===========================================
# 适用于所有子目录的忽略规则
# ===========================================

# ---------- 敏感配置与环境变量 ----------
**/.env
**/*.env
!**/.env.example

# ---------- Python 缓存与虚拟环境 ----------
**/__pycache__/
**/*.py[cod]
**/*.so
**/.Python
**/venv/
**/env/
**/.venv/
**/pip-log.txt
**/pip-delete-this-directory.txt

# ---------- 数据库文件 ----------
**/*.db
**/*.sqlite
**/*.sqlite3
**/data/*.db

# ---------- IDE 与编辑器配置 ----------
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~
**/.DS_Store
**/Thumbs.db

# ---------- 日志与临时文件 ----------
**/*.log
**/*.tmp
**/*.temp

# ---------- 打包与构建产物 ----------
**/dist/
**/build/
**/*.egg-info/
**/*.egg
**/.eggs/

# ---------- Docker 相关（仅限开发版，不影响其他） ----------
# Docker 镜像构建产物不需要提交
**/docker-compose.override.yml

# ---------- 操作系统特定文件（若在 macOS 上打包） ----------
**/.DS_Store
**/._*
**/.Spotlight-V100
**/.Trashes
**/ehthumbs.db
**/Thumbs.db
